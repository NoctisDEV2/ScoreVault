# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
SUBSCRIBER_ROLE_ID=123456789012345678       # Discord role ID for active subscribers

# Map channel IDs to games: "channelId:Game,channelId2:Game2"
# Example: CHANNEL_GAME_MAP=111222333444555666:Valorant,777888999000111222:CS2
CHANNEL_GAME_MAP=

# ── API ───────────────────────────────────────────────────────────────────────
PORT=4000
API_URL=http://api:4000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://scorevault:devsecret@postgres:5432/scorevault
POSTGRES_PASSWORD=devsecret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Service-to-service HMAC ───────────────────────────────────────────────────
# Shared secret between API, Bot, and OCR worker.
# Generate with: openssl rand -hex 32
INTERNAL_SECRET=change_me_generate_with_openssl_rand_hex_32

# ── Stripe (Phase 4) ─────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Blockchain (Phase 2) ──────────────────────────────────────────────────────
# POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
# RELAYER_PRIVATE_KEY=0x...
# MATCH_REGISTRY_ADDRESS=0x...

# ── IPFS (Phase 2) ────────────────────────────────────────────────────────────
# IPFS_API_URL=https://api.pinata.cloud
# IPFS_API_KEY=...
# IPFS_API_SECRET=...

# ── Riot API ──────────────────────────────────────────────────────────────────
# Get from https://developer.riotgames.com (personal key) or production app key
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Regional routing: americas | europe | asia | esports
RIOT_REGION=americas

# ── Gemini Vision API ─────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# 